<Application x:Class="MiniGoods.Inventory.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:MiniGoods.Inventory.WPF"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>

            <!-- ===== 颜色画刷 ===== -->
            <SolidColorBrush x:Key="SidebarBg"      Color="#1E3A5F"/>
            <SolidColorBrush x:Key="SidebarHeader"  Color="#142D4E"/>
            <SolidColorBrush x:Key="SidebarHover"   Color="#2D5A8E"/>
            <SolidColorBrush x:Key="SidebarActive"  Color="#1A6FC4"/>
            <SolidColorBrush x:Key="SidebarText"    Color="#BDD5EE"/>
            <SolidColorBrush x:Key="ContentBg"      Color="#F4F6F9"/>
            <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF"/>
            <SolidColorBrush x:Key="BorderGray"     Color="#DDE2EA"/>

            <SolidColorBrush x:Key="PrimaryBrush"   Color="#1976D2"/>
            <SolidColorBrush x:Key="PrimaryDark"    Color="#1565C0"/>
            <SolidColorBrush x:Key="DangerBrush"    Color="#E53935"/>
            <SolidColorBrush x:Key="DangerDark"     Color="#C62828"/>
            <SolidColorBrush x:Key="SuccessBrush"   Color="#43A047"/>
            <SolidColorBrush x:Key="SuccessDark"    Color="#2E7D32"/>
            <SolidColorBrush x:Key="WarningBrush"   Color="#FB8C00"/>
            <SolidColorBrush x:Key="NeutralBrush"   Color="#607D8B"/>

            <!-- ===== 导航按钮样式 ===== -->
            <Style x:Key="NavButtonStyle" TargetType="Button">
                <Setter Property="Background"              Value="Transparent"/>
                <Setter Property="Foreground"              Value="{StaticResource SidebarText}"/>
                <Setter Property="BorderThickness"         Value="0"/>
                <Setter Property="FontSize"                Value="14"/>
                <Setter Property="Height"                  Value="46"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding"                 Value="22,0,0,0"/>
                <Setter Property="Cursor"                  Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource SidebarHover}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="{StaticResource SidebarActive}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===== 通用圆角按钮基础模板 ===== -->
            <ControlTemplate x:Key="RoundButtonTemplate" TargetType="Button">
                <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        CornerRadius="4"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                    </Trigger>
                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="bd" Property="Opacity" Value="0.75"/>
                    </Trigger>
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- Primary 蓝色按钮 -->
            <Style x:Key="PrimaryBtn" TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource PrimaryBrush}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="16,7"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template"        Value="{StaticResource RoundButtonTemplate}"/>
            </Style>

            <!-- Danger 红色按钮 -->
            <Style x:Key="DangerBtn" TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource DangerBrush}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="14,7"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template"        Value="{StaticResource RoundButtonTemplate}"/>
            </Style>

            <!-- Success 绿色按钮 -->
            <Style x:Key="SuccessBtn" TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource SuccessBrush}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="14,7"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template"        Value="{StaticResource RoundButtonTemplate}"/>
            </Style>

            <!-- Warning 橙色按钮 -->
            <Style x:Key="WarningBtn" TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource WarningBrush}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="14,7"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template"        Value="{StaticResource RoundButtonTemplate}"/>
            </Style>

            <!-- Neutral 灰色按钮 -->
            <Style x:Key="NeutralBtn" TargetType="Button">
                <Setter Property="Background"      Value="{StaticResource NeutralBrush}"/>
                <Setter Property="Foreground"      Value="White"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding"         Value="14,7"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Cursor"          Value="Hand"/>
                <Setter Property="Template"        Value="{StaticResource RoundButtonTemplate}"/>
            </Style>

            <!-- ===== 页面标题样式 ===== -->
            <Style x:Key="PageTitle" TargetType="TextBlock">
                <Setter Property="FontSize"     Value="20"/>
                <Setter Property="FontWeight"   Value="SemiBold"/>
                <Setter Property="Foreground"   Value="#1A2B45"/>
                <Setter Property="Margin"       Value="0,0,0,4"/>
            </Style>

            <Style x:Key="PageSubtitle" TargetType="TextBlock">
                <Setter Property="FontSize"     Value="12"/>
                <Setter Property="Foreground"   Value="#7A8FA6"/>
            </Style>

            <!-- ===== DataGrid 全局样式 ===== -->
            <Style TargetType="DataGrid">
                <Setter Property="GridLinesVisibility"   Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#EEF0F4"/>
                <Setter Property="BorderBrush"           Value="{StaticResource BorderGray}"/>
                <Setter Property="BorderThickness"       Value="1"/>
                <Setter Property="Background"            Value="White"/>
                <Setter Property="RowBackground"         Value="White"/>
                <Setter Property="AlternatingRowBackground" Value="#FAFBFD"/>
                <Setter Property="SelectionMode"         Value="Single"/>
                <Setter Property="CanUserResizeRows"     Value="False"/>
                <Setter Property="ColumnHeaderStyle">
                    <Setter.Value>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background"  Value="#EDF2F7"/>
                            <Setter Property="Foreground"  Value="#2D3748"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                            <Setter Property="FontSize"    Value="13"/>
                            <Setter Property="Height"      Value="38"/>
                            <Setter Property="Padding"     Value="12,0"/>
                            <Setter Property="BorderBrush" Value="#DDE2EA"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </Setter.Value>
                </Setter>
                <Setter Property="RowStyle">
                    <Setter.Value>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height"   Value="36"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EBF3FD"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>
                <Setter Property="CellStyle">
                    <Setter.Value>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding"          Value="10,0"/>
                            <Setter Property="BorderThickness"  Value="0"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background"      Value="Transparent"/>
                                    <Setter Property="Foreground"      Value="#1A2B45"/>
                                    <Setter Property="BorderBrush"     Value="Transparent"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===== TextBox 全局样式 ===== -->
            <Style TargetType="TextBox">
                <Setter Property="BorderBrush"     Value="{StaticResource BorderGray}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="8,6"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Background"      Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                    <Setter TargetName="border" Property="BorderThickness" Value="1.5"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="border" Property="Background" Value="#F7F8FA"/>
                                    <Setter TargetName="border" Property="BorderBrush" Value="#DDE2EA"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ===== ComboBox 全局样式 ===== -->
            <Style TargetType="ComboBox">
                <Setter Property="BorderBrush"     Value="{StaticResource BorderGray}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding"         Value="8,5"/>
                <Setter Property="FontSize"        Value="13"/>
                <Setter Property="Background"      Value="White"/>
                <Setter Property="Height"          Value="34"/>
            </Style>

            <!-- ===== Label 字段标签样式 ===== -->
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontSize"   Value="12"/>
                <Setter Property="Foreground" Value="#4A5568"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin"     Value="0,0,0,4"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
