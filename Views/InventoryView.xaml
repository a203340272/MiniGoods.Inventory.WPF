<UserControl x:Class="MiniGoods.Inventory.WPF.Views.InventoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource ContentBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📊" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="库存总览" Style="{StaticResource PageTitle}"/>
                        <TextBlock Text="实时查看各商品库存，库存 ≤ 10 自动红色高亮预警" Style="{StaticResource PageSubtitle}"/>
                    </StackPanel>
                </StackPanel>

                <Button DockPanel.Dock="Right" Content="🔄 刷新"
                        Command="{Binding LoadCommand}"
                        Style="{StaticResource NeutralBtn}"
                        VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <!-- 低库存说明卡片 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 低库存提示横幅 -->
            <Border Grid.Row="0" Background="#FFF3E0" BorderBrush="#FFB74D" BorderThickness="1"
                    CornerRadius="4" Padding="12,8" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⚠️" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock FontSize="12" Foreground="#E65100" VerticalAlignment="Center">
                        <Run Text="库存预警：库存数量 ≤ 10 件的商品将以"/>
                        <Run Text="红色" Foreground="#D32F2F" FontWeight="Bold"/>
                        <Run Text="高亮显示，请及时安排补货。"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- 库存数据表格 -->
            <Border Grid.Row="1" Background="White"
                    BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="6">
                <DataGrid ItemsSource="{Binding Items}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          Margin="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"      Binding="{Binding ProductID}" Width="50"/>
                        <DataGridTextColumn Header="商品名称" Binding="{Binding Name}"      Width="*"/>
                        <DataGridTextColumn Header="条形码"  Binding="{Binding Barcode}"   Width="120"/>
                        <DataGridTextColumn Header="商品分类" Binding="{Binding Category}"  Width="80"/>
                        <DataGridTextColumn Header="单价(¥)"  Binding="{Binding Price, StringFormat={}{0:F2}}" Width="80"/>

                        <!-- 库存列：低库存时红色高亮 -->
                        <DataGridTextColumn Header="库存（件）" Binding="{Binding Stock}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight"        Value="Normal"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                            <Setter Property="Foreground" Value="#D32F2F"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 状态列 -->
                        <DataGridTemplateColumn Header="状态" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E8F5E9"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                        <Setter Property="Background" Value="#FFEBEE"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text"       Value="正常"/>
                                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                                            <Setter Property="Text"       Value="库存不足"/>
                                                            <Setter Property="Foreground" Value="#C62828"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                    <!-- 低库存整行背景 -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="38"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                                    <Setter Property="Background" Value="#FFF8F8"/>
                                </DataTrigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#EBF3FD"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#BBDEFB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
