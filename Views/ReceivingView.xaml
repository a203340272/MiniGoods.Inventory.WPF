<UserControl x:Class="MiniGoods.Inventory.WPF.Views.ReceivingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource ContentBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="🚚" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="上货入库" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="选择商品，填写入库数量，确认后自动更新库存并记录历史" Style="{StaticResource PageSubtitle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 主体：商品列表 -->
        <Border Grid.Row="1" Background="White" Margin="20,16,20,8"
                BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,10"
                        BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="🔄 刷新商品列表" Command="{Binding LoadCommand}"
                                Style="{StaticResource NeutralBtn}"/>
                        <TextBlock Text="点击行以选中商品" FontSize="12" Foreground="#7A8FA6"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                          Margin="1,0,1,1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"       Binding="{Binding ProductID}" Width="50"/>
                        <DataGridTextColumn Header="名称"     Binding="{Binding Name}"      Width="*"/>
                        <DataGridTextColumn Header="条码"     Binding="{Binding Barcode}"   Width="120"/>
                        <DataGridTextColumn Header="分类"     Binding="{Binding Category}"  Width="80"/>
                        <DataGridTextColumn Header="当前库存" Binding="{Binding Stock}"      Width="80"/>
                        <DataGridTextColumn Header="单价(¥)"  Binding="{Binding Price, StringFormat={}{0:F2}}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 底部操作栏 -->
        <Border Grid.Row="2" Background="White" Margin="20,0,20,20"
                BorderBrush="{StaticResource BorderGray}" BorderThickness="1" CornerRadius="6"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 选中提示 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="已选商品：" FontSize="13" Foreground="#4A5568" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SelectedProduct.Name, FallbackValue='（请在列表中选择）'}"
                               FontSize="13" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                </StackPanel>

                <!-- 入库数量 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="入库数量（件）：" FontSize="13" Foreground="#4A5568"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding ReceiveQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="100" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 确认按钮 -->
                <Button Grid.Column="2"
                        Content="✅ 确认入库"
                        Command="{Binding ConfirmReceiveCommand}"
                        Style="{StaticResource SuccessBtn}"
                        FontSize="14" Padding="20,9"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
