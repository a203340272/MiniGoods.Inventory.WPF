<UserControl x:Class="MiniGoods.Inventory.WPF.Views.ProductManageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MiniGoods.Inventory.WPF.Converters">
    <UserControl.Resources>
        <conv:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource ContentBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Background="White"
                BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1"
                Padding="24,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📦" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock Text="商品管理" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="新增、修改、删除商品信息" Style="{StaticResource PageSubtitle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 主体内容 -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左：列表区 -->
            <Border Grid.Column="0" Background="White"
                    BorderBrush="{StaticResource BorderGray}" BorderThickness="1"
                    CornerRadius="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 工具栏 -->
                    <Border Grid.Row="0" Padding="12,10"
                            BorderBrush="{StaticResource BorderGray}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔄 刷新"    Command="{Binding LoadCommand}"
                                    Style="{StaticResource NeutralBtn}" Margin="0,0,8,0"/>
                            <Button Content="➕ 新增"    Command="{Binding AddCommand}"
                                    Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <Button Content="✏️ 修改"   Command="{Binding UpdateCommand}"
                                    Style="{StaticResource WarningBtn}" Margin="0,0,8,0"/>
                            <Button Content="🗑️ 删除"   Command="{Binding DeleteCommand}"
                                    Style="{StaticResource DangerBtn}"  Margin="0,0,8,0"/>
                            <Button Content="✖ 清空表单" Command="{Binding ClearFormCommand}"
                                    Style="{StaticResource NeutralBtn}"/>
                        </StackPanel>
                    </Border>

                    <!-- 数据表格 -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Products}"
                              SelectedItem="{Binding SelectedProduct}"
                              IsSynchronizedWithCurrentItem="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              Margin="1,0,1,1">
                        <DataGrid.Columns>
                            <!-- 图标缩略图列 -->
                            <DataGridTemplateColumn Width="52" Header="图标" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Width="36" Height="36" CornerRadius="4"
                                                Background="#F0F4F8" ClipToBounds="True"
                                                HorizontalAlignment="Center">
                                            <Grid>
                                                <!-- 无图标时的占位符（当 Image 透明时穿透可见） -->
                                                <TextBlock Text="🏷" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                <!-- 图标图片，Source=null 时透明，覆盖在占位符上方 -->
                                                <Image Source="{Binding IconData,
                                                                         Converter={StaticResource ByteArrayToImage}}"
                                                       Stretch="UniformToFill"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="ID"       Binding="{Binding ProductID}"                   Width="50"/>
                            <DataGridTextColumn Header="名称"     Binding="{Binding Name}"                        Width="*"/>
                            <DataGridTextColumn Header="条码"     Binding="{Binding Barcode}"                     Width="120"/>
                            <DataGridTextColumn Header="分类"     Binding="{Binding Category}"                    Width="80"/>
                            <DataGridTextColumn Header="价格(¥)" Binding="{Binding Price, StringFormat={}{0:F2}}" Width="80"/>
                            <DataGridTextColumn Header="库存"     Binding="{Binding Stock}"                       Width="60"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- 分隔 -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                          Background="Transparent"/>

            <!-- 右：表单区 -->
            <Border Grid.Column="2" Background="White"
                    BorderBrush="{StaticResource BorderGray}" BorderThickness="1"
                    CornerRadius="6" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="商品信息" FontSize="14" FontWeight="Bold"
                                   Foreground="#1A2B45" Margin="0,0,0,16"/>

                        <!-- ── 图标区 ── -->
                        <TextBlock Text="商品图标" Style="{StaticResource FieldLabel}"/>
                        <!-- 预览框：占位 emoji 在下层，图片在上层（有图时覆盖） -->
                        <Border Width="110" Height="110"
                                CornerRadius="8"
                                Background="#F8FAFC"
                                BorderBrush="{StaticResource BorderGray}" BorderThickness="1"
                                ClipToBounds="True"
                                HorizontalAlignment="Left"
                                Margin="0,4,0,8">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="🏷" FontSize="36"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="暂无图标" FontSize="11"
                                               Foreground="#9BA3AF"
                                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                                <Image Source="{Binding IconData, Converter={StaticResource ByteArrayToImage}}"
                                       Stretch="UniformToFill"/>
                            </Grid>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Button Content="📤 上传图标"
                                    Command="{Binding UploadIconCommand}"
                                    Style="{StaticResource NeutralBtn}"
                                    Margin="0,0,8,0"/>
                            <Button Content="✖ 清除图标"
                                    Command="{Binding ClearIconCommand}"
                                    Style="{StaticResource NeutralBtn}"/>
                        </StackPanel>

                        <Separator Margin="0,0,0,16"/>

                        <!-- ── 基本信息字段 ── -->
                        <TextBlock Text="商品名称 *" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Text="{Binding Name,     UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="条形码" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Text="{Binding Barcode,  UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="商品分类" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="销售价格（元）*" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Text="{Binding Price,    UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                        <TextBlock Text="当前库存（件）" Style="{StaticResource FieldLabel}"/>
                        <TextBox   Text="{Binding Stock,    UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                        <Separator Margin="0,0,0,16"/>

                        <StackPanel Orientation="Horizontal">
                            <Button Content="✅ 新增"      Command="{Binding AddCommand}"
                                    Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0"/>
                            <Button Content="💾 保存修改"  Command="{Binding UpdateCommand}"
                                    Style="{StaticResource SuccessBtn}"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
