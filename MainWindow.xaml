<Window
    x:Class="MiniGoods.Inventory.WPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="迷你上货 · 单机库存管理系统"
    Width="1060"
    Height="660"
    Background="{StaticResource ContentBg}"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  ===== 左侧导航栏 =====  -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}">
            <DockPanel>

                <!--  顶部 Logo 区域  -->
                <Border
                    Padding="0,24,0,20"
                    Background="{StaticResource SidebarHeader}"
                    DockPanel.Dock="Top">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock
                            Margin="0,0,0,8"
                            HorizontalAlignment="Center"
                            FontSize="34"
                            Text="📦" />
                        <TextBlock
                            HorizontalAlignment="Center"
                            FontSize="15"
                            FontWeight="Bold"
                            Foreground="White"
                            Text="迷你上货" />
                        <TextBlock
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            FontSize="11"
                            Foreground="#7EAED4"
                            Text="单机库存管理系统" />
                    </StackPanel>
                </Border>

                <!--  分隔线  -->
                <Rectangle
                    Height="1"
                    Margin="16,8"
                    DockPanel.Dock="Top"
                    Fill="#2A4A6E" />

                <!--  菜单标题  -->
                <TextBlock
                    Margin="22,6,0,6"
                    DockPanel.Dock="Top"
                    FontSize="10"
                    FontWeight="Bold"
                    Foreground="#5A7FA0"
                    Text="功能菜单" />

                <!--  导航按钮  -->
                <StackPanel DockPanel.Dock="Top">
                    <Button
                        Command="{Binding ShowProductManageCommand}"
                        Content="📦   商品管理"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Command="{Binding ShowReceivingCommand}"
                        Content="🚚   上货入库"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Command="{Binding ShowInventoryCommand}"
                        Content="📊   库存总览"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Command="{Binding ShowPriceHistoryCommand}"
                        Content="💰   价格历史"
                        Style="{StaticResource NavButtonStyle}" />
                    <Button
                        Command="{Binding ShowVoiceQueryCommand}"
                        Content="🎤   语音查询"
                        Style="{StaticResource NavButtonStyle}" />
                </StackPanel>

                <!--  底部版本号  -->
                <TextBlock
                    Margin="0,0,0,16"
                    HorizontalAlignment="Center"
                    DockPanel.Dock="Bottom"
                    FontSize="11"
                    Foreground="#3A5A7A"
                    Text="v1.0.0 · 单机版" />
            </DockPanel>
        </Border>

        <!--  ===== 右侧内容区 =====  -->
        <ContentControl
            Grid.Column="1"
            Background="{StaticResource ContentBg}"
            Content="{Binding CurrentView}" />
    </Grid>
</Window>
